PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.example.mongodb.net/your_db_name

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_prod
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Email Configuration
# ─── OPTION 1: Google Apps Script (No domain needed) ───
GOOGLE_SCRIPT_URL=your-google-script-web-app-url

# Client origin (update this to your Vercel URL in production)
CLIENT_URL=https://smart-career-roadmap-generator.vercel.app
